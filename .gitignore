audio-cache/

###############################################################################
# Local overrides and secrets
###############################################################################

# Local config overrides
*.local.json
*.local.toml
*.local.yaml
*.local.yml

# Env / secrets (never commit real keys)
.env
.env.*
*.key
*.pem
*.crt
*.pfx

