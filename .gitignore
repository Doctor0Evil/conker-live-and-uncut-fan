###############################################################################

*.mlx
*.mlappinstall
*.mltbx
*.mlapp
*.mlproj
*.mexa64
*.mexmaci64
*.mexw64
*.p

###############################################################################
# Lua
###############################################################################

*.luac
.luacheckrc

###############################################################################
# Asset pipeline scratch (images / audio / intermediates)
###############################################################################

# Large raw assets (prefer Git LFS if you really need them tracked)
*.fbx
*.blend
*.psd
*.aiff
*.wav
*.mp3
*.ogg
*.umap
*.uasset
*.tscn
*.tres
*.unity
*.prefab

# Generated atlases, intermediate textures/audio
*.atlas.tmp
*.png.tmp
*.wav.tmp
*.ogg.tmp
*.flac.tmp

# Tool-specific caches (e.g., texture/audio packers)
texture-cache/
audio-cache/

###############################################################################
# Local overrides and secrets
###############################################################################

# Local config overrides
*.local.json
*.local.toml
*.local.yaml
*.local.yml

# Env / secrets (never commit real keys)
.env
.env.*
*.env
*.local
*.secret
*.key
*.pem
*.crt
*.pfx
credentials.json
service-account.json

###############################################################################
# Git metadata (submodules etc.)
###############################################################################

.gitmodules.lock
