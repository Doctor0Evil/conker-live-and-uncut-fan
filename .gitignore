# Cargo build output
target/
**/target/

# C/C++ build directories
build/
**/build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
Makefile
CMakeScripts/
Testing/
compile_commands.json

# Libs / binaries
*.o
*.obj
*.lo
*.la
*.a
*.lib
*.dll
*.so
*.dylib
*.exe
*.pdb
*.dll.lib

