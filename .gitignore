# conker-live-and-uncut-fan/.gitignore

###############################################################################
# Rust / C / C++ build artifacts
###############################################################################

# Cargo build output
/target/
/**/target/

# Optional: ignore Cargo.lock for workspace-style dev (keep if you want lockfile pinned)
#/Cargo.lock

# C/C++ build directories
/build/
/**/build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
Makefile
CMakeScripts/
Testing/
compile_commands.json

# Compiled libs / binaries
*.o
*.obj
*.lo
*.la
*.a
*.lib
*.dll
*.so
*.dylib
*.exe
*.pdb
*.dll.lib
*.rs.bk

###############################################################################
# Engine and editor generated content (Unity / UE / Godot / others)
###############################################################################

# Unity
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uilds/
/[Bb]uild/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/Assets/AssetStoreTools*
*.unityproj
*.unitypackage
*.pidb
*.pidb.meta
*.pdb.meta
*.dll.meta
*.exe.meta
*.unity.meta
*.prefab.meta
*.anim.meta
*.controller.meta
*.mat.meta
*.shader.meta
*.asset.meta
*.fbx.meta
*.png.meta
*.jpg.meta
*.tga.meta
*.psd.meta
*.wav.meta
*.mp3.meta

# Unreal Engine 5
/Binaries/
/Build/
/Intermediate/
/Saved/
/DerivedDataCache/

# UE editor / IDE caches
.vs/
.idea/
*.sln
*.suo
*.user
*.userosscache
*.userprefs
*.pidb
*.sdf
*.opensdf
*.VC.db
*.VC.opendb

# UE content that should not be committed
Content/Developers/
Content/Collections/
Content/Localization/

# Platform-specific generated content under Content
Content/*/Android/
Content/*/IOS/
Content/*/Linux/
Content/*/Mac/
Content/*/PS5/
Content/*/XboxSeries/

# Godot
.godot/
/.export/
/.import/
/export.cfg
export-*.cfg
.export-presets.cfg
*.import
*.import-remap
*.remap
*.uid
*.tmp
*.import-*.tmp
.project_metadata/
*.translation

###############################################################################
# Retro / ROM / emulator outputs
###############################################################################

# Built ROMs & ISOs
*.nes
*.sfc
*.smc
*.z64
*.n64
*.v64
*.iso
*.bin
*.cue
*.img

# Emulator saves and caches
*.sav
*.srm
*.eep
*.fla
*.mcr
*.state
*.st0
*.st1
*.[Ss]tates
*.rtc

# Emulator logs / traces / captures
*.dmp
*.log
*.trace
*.pcap

# N64 / PS1 specific temp outputs
conk64-logs/
conk64-traces/
ps1-build-cache/
n64-build-cache/

###############################################################################
# AI, artifacts, Starzip / Sonia outputs
###############################################################################

# Sonia / Starzip artifact trees
/artifacts/
/**/artifacts/

# Packaged builds / distributions
/dist/
/**/dist/

# Build outputs tracked separately
Build/artifacts/
Build/releases/
Build/*.zip
Build/*.tar.gz

# Local AI / chat session state
.gamemodeai-session*/
.gamemodeai-session*.json
.ai-chat-cache/
*.ai-session-local.json

###############################################################################
# CI and tool scratch dirs
###############################################################################

.tmp/
tmp/
.cache/
.npm/
node_modules/
.coverage/
coverage/
htmlcov/

###############################################################################
# IDEs, editors, OS files
###############################################################################

# VS Code
.vscode/
.history/

# JetBrains
.idea/
*.iml
out/

# Visual Studio (some overlap with UE section)
.vs/
*.suo
*.user
*.userosscache

# Other editors
*.swp
*.swo
*~
.#*
*.orig
*.sublime-*
*.code-workspace
.project

# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux / misc
*~
.nfs*

###############################################################################
# Logs, test outputs, temporary data
###############################################################################

*.log
/logs/
/**/logs/
Logs/
CrashReportClient/
*.tmp
*.bak
*.old

# Test and fuzz outputs
fuzz-artifacts/
fuzz-output/
test-output/
/**/test-output/

###############################################################################
# Python / tooling helpers
###############################################################################

__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.mypy_cache/
pytest_cache/

