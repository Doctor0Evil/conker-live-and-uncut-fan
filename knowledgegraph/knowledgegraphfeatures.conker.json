{
  "repo": "Doctor0Evil/Conker-Live-Uncut-UE5",
  "version": "0.1.0",
  "features": [
    {
      "id": "conker.ue5.core.character",
      "title": "Conker UE5 Core Character Mechanic",
      "description": "Deterministic character movement, health, camera hooks, and emote/voice triggers implemented by CLUCharacterBase and UE5 animation assets.",
      "tags": [
        "UE5",
        "Deterministic",
        "Mechanic",
        "Character"
      ],
      "systems": [
        "systems.ue5.conker.core.character",
        "systems.ue5.conker.content.characters",
        "systems.ue5.conker.content.blueprints"
      ],
      "schemas": [
        "schemas/conker/character.mechanic.schema.json"
      ],
      "examples": [
        "docs/examples/conker/character/basic_move_and_emote.md"
      ],
      "roles": [
        "MechanicDesigner",
        "AIChatNavigation"
      ],
      "commands": [
        "gamemodeai-kg:getsystem",
        "gamemodeai-kg:listdependents"
      ],
      "stability": "experimental"
    },
