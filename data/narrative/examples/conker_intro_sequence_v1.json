{
  "$schema": "https://github.com/Doctor0Evil/conker-live-and-uncut-fan/schemas/narrative/sequence_v1.schema.json",
  "id": "SEQ_ALIENBASE_INTRO_CONKER",
  "title": "Conker's Alien Base Arrival - Intro Sequence",
  "entry_beat_id": "BEAT_ARRIVAL_LANDING",
  "beats": {
    "BEAT_ARRIVAL_LANDING": {
      "id": "BEAT_ARRIVAL_LANDING",
      "label": "Conker crash-lands in Alien Base hub",
      "type": "intro",
      "sfx_id": "SFX_303",
      "vfx_id": "VFX_112",
      "asid_id": "ASID_451",
      "dialog_lines": [
        {
          "speaker": "CONKER",
          "text": "Blimey! That's the last time I trust a 'shortcut' from a talking mushroom.",
          "emotion": "Confused",
          "duration_hint_s": 4.5,
          "sfx_override": "SFX_501"
        }
      ],
      "conditions": [],
      "effects": [
        {
          "type": "SetFlag",
          "target": "player.arrived_alienbase",
          "parameters": { "value": true }
        }
      ],
      "branches": [
        {
          "id": "BRANCH_EXPLORE_HUB",
          "label": "Look around the hub",
          "next_beat_id": "BEAT_HUB_EXPLORATION",
          "choice_text": "What's this place, then?"
        },
        {
          "id": "BRANCH_FIND_EXIT",
          "label": "Search for a way out",
          "next_beat_id": "BEAT_SEARCH_EXIT",
          "choice_text": "Right, let's find the exit before anything bites me."
        }
      ],
      "ai_metadata": {
        "tags": ["intro", "comedy", "alienbase"],
        "prompt_hint": "Generate a confused CONKER arrival line with environmental SFX",
        "difficulty": 1,
        "estimated_duration_s": 12.0,
        "content_notes": ["mild language"]
      }
    },
