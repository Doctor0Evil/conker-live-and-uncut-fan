      "type": "trigger",
      "sfx_id": "SFX_304",
      "dialog_lines": [
        {
          "speaker": "CONKER",
          "text": "Creepy organic walls, pulsing eggs, suspicious vents... this place gives me the willies.",
          "emotion": "Fearful",
          "duration_hint_s": 5.0
        }
      ],
      "conditions": [
        {
          "type": "ZoneActive",
          "parameter": "ZONE_AB_HUB_CENTER",
          "operator": "Eq",
          "value": true
        }
      ],
      "effects": [
        {
          "type": "TriggerCinematic",
          "target": "CAMERA_PAN_EGG",
          "parameters": { "duration_s": 3.0 }
