        {
          "id": "BRANCH_INVESTIGATE_EGG",
          "label": "Check out the weird egg",
          "next_beat_id": "BEAT_EGG_DISCOVERY",
          "choice_text": "That egg's pulsing. Probably not a good sign."
        }
      ],
      "ai_metadata": {
        "tags": ["exploration", "atmosphere", "alienbase"],
        "difficulty": 1,
        "estimated_duration_s": 8.0
      }
    },
    "BEAT_EGG_DISCOVERY": {
      "id": "BEAT_EGG_DISCOVERY",
      "label": "Conker discovers Alien Egg objective",
      "type": "objective",
      "sfx_id": "SFX_304",
      "vfx_id": "VFX_017",
      "dialog_lines": [
        {
          "speaker": "CONKER",
          "text": "Right. Massive alien egg. Probably wants hatching. Probably wants to eat me. Classic.",
          "emotion": "Sarcastic",
          "duration_hint_s": 4.0,
          "sfx_override": "SFX_502"
        }
      ],
      "conditions": [],
      "effects": [
        {
          "type": "GrantItem",
          "target": "player",
          "parameters": { "item": "OBJ_ALIEN_EGG_KEY", "quantity": 1 }
        },
        {
          "type": "SetFlag",
          "target": "objective.egg_discovered",
          "parameters": { "value": true }
